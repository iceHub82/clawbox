# OpenClaw Docker Kit — Environment Configuration
# Copy this file to .env and adjust as needed.

# Image (default: pre-built from GHCR)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Data directories (default: ./data/ subdirectories)
OPENCLAW_CONFIG_DIR=./data/config
OPENCLAW_WORKSPACE_DIR=./data/workspace

# Network binding (127.0.0.1 = localhost only, 0.0.0.0 = LAN-accessible)
BIND_HOST=127.0.0.1

# Gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_GATEWAY_TOKEN=  # Generated during setup

# SearXNG
SEARXNG_PORT=8888

# Optional
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
